# Local PostgreSQL configuration
POSTGRES_DB=auditor
POSTGRES_USER=auditor
POSTGRES_PASSWORD=auditor_local_dev
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://auditor:auditor_local_dev@localhost:5432/auditor

# Local Redis configuration
REDIS_BIND_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Local-only Ollama configuration
OLLAMA_IMAGE=ollama/ollama:0.31.1
OLLAMA_BIND_HOST=127.0.0.1
OLLAMA_PORT=11435
OLLAMA_BASE_URL=http://127.0.0.1:11435
OLLAMA_INSTRUCTION_MODEL=qwen3:4b-instruct
OLLAMA_EMBEDDING_MODEL=embeddinggemma
OLLAMA_REQUEST_TIMEOUT_SECONDS=180
OLLAMA_MAX_CONCURRENCY=1
OLLAMA_KEEP_ALIVE=5m

# FastAPI runtime configuration
APP_ENVIRONMENT=development
APP_LOG_LEVEL=INFO
READINESS_TIMEOUT_SECONDS=2
